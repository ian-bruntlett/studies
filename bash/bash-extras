# cdrm - change to parent directory, remove that child directory (must be empty).
# if the old directory cannot be deleted, stay in that directory so you can
# work on those files.
cdrm()
{
    # shellcheck disable=SC2164
    cd ..
    if ! rmdir -v "$OLDPWD" ; then
	echo -en "\aFAILED: Still in : " 1>&2
        # shellcheck disable=SC2164
	cd -
    fi
}

# mkcd - make a directory and change into it.
mkcd()
{
    if ! mkdir -p "$1" ; then
	echo -e "\aFAILED to mkdir : " 1>&2
    else
        # shellcheck disable=SC2164
        cd "$1"
    fi	
}
